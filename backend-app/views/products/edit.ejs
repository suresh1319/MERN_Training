<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Edit Product</h2>
    <form action="/products/<%= product._id %>/save" method="POST">
         <input type="text" name="name" value="<%= product.name %>" placeholder="Enter Product Name" required>
        <input type="number" name="price" value="<%= product.price %>" required>
        <input name="description" value="<%= product.description %>" id="">
        <input type="text" name="image" value="<%= product.image %>" required>
        <button type="submit">Save Product</button>
    </form>
</body>
</html>