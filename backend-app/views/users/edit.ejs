<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Add User</h2>
    <form method="POST" action = "/users/<%= user._id %>/save">
        <input type="text" name="name" placeholder="Enter Name" value="<%= user.name %>" required>
        <input type="email" name="email" placeholder="Enter Email" value="<%= user.email %>" required>
        <input type="password" placeholder="enter password" name="password" value="<%= user.password %>" required>
        <input type="text" placeholder="enter role" name="role" value="<%= user.role %>" required>
        <button type="submit">Add User</button>
    </form>
</body>
</html>