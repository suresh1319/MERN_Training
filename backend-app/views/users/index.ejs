<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Users</h2>
    <a href="/users/add">Add User</a>
    <% users.forEach((user)=>{ %>
        <p><%= user.name %> - <%= user.email %> - <%= user.password %> - <%= user.role %>-<a href="/users/<%= user._id %>/delete">Delete</a>-<a href="/users/<%= user._id %>/edit">Edit</a></p>
    <% }) %>
</body>
</html>